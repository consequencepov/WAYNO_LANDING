{
  "name": "wayno-black",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:spa": "tsc -b && vite build",
    "build": "tsc -b && vite build",
    "build:prerender": "export PUPPETEER_EXECUTABLE_PATH='/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' && npm run build:spa && react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/404.html",
      "/ai-konstruktor-saytov",
      "/sozdanie-lendinga-s-pomoshyu-ai",
      "/mvp-dlya-startapa",
      "/sayt-po-referensu",
      "/proverka-biznes-gipotez",
      "/sayt-dlya-agentstva-i-dizaynera",
      "/ai-sayt-dlya-saas",
      "/landing-dlya-lidogeneratsii",
      "/sayt-dlya-uslug",
      "/modernizatsiya-starogo-sayta",
      "/landing-telegram-mini-app",
      "/sayt-dlya-b2b-postavshika",
      "/landing-dlya-novogo-produkta",
      "/sayt-dlya-obrazovatelnogo-produkta"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.3.1",
    "framer-motion": "^11.11.0",
    "lenis": "^1.1.14",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^9.13.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/edge": "^1.2.2",
    "@vercel/node": "^5.7.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.4.49",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.0.1"
  }
}
