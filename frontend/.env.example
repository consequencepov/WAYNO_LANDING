# ──────────────────────────────────────────────────
#  WAYNO — Environment Variables
# ──────────────────────────────────────────────────
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git (it's in .gitignore).

# ── Frontend (exposed to browser via Vite) ──
# These are PUBLIC keys — safe to embed in the client bundle.
# Access is controlled by Supabase RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# ── Server-only (set in Vercel Dashboard → Settings → Environment Variables) ──
# NEVER use VITE_ prefix — these must stay server-side only.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# The service role key bypasses RLS — used ONLY by
# api/submit-lead.ts to write leads. If this key leaks,
# an attacker can read/write ALL data in your project.
